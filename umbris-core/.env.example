# UMBRIS · environment template.
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#

# Required. Your Anthropic API key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Override default models per tier.
# UMBRIS_WORKER_MODEL=claude-opus-4-7
# UMBRIS_MERCURIUS_MODEL=claude-sonnet-4-6
# UMBRIS_IUPPITER_MODEL=claude-opus-4-7
# UMBRIS_SATURNUS_MODEL=claude-opus-4-7

# Optional. Hard ceiling on total USD per revolution. Default: unbounded for v1.1.
# UMBRIS_BUDGET_USD=2.00

# Optional. Hard ceiling on planet rounds per revolution. Default: 3.
# UMBRIS_MAX_ROUNDS=3

# Optional. Path for provenance JSONL output. Default: ./provenance/
# UMBRIS_PROVENANCE_DIR=./provenance
