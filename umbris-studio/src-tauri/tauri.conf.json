{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UMBRIS Studio",
  "version": "1.1.0",
  "identifier": "llm.umbris.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "UMBRIS Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#000000",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "The convocation, given form.",
    "longDescription": "UMBRIS Studio is the desktop HUD for the UMBRIS planetary convocation. Cast queries, watch nine planetary intelligences deliberate live on the Eclipse Orb, receive verified verdicts, operate the autonomous Custos sentinel. Open-source under MIT."
  },
  "plugins": {}
}
