# UMBRIS · environment template
#
# Copy this file to `.env` (in this directory or in umbris-core/) and fill in
# the keys for the provider(s) you want the convocation to use.
#
#   cp .env.example umbris-core/.env
#   ${EDITOR:-nano} umbris-core/.env
#
# Provider resolution order:
#   1. UMBRIS_PROVIDER env var (explicit)
#   2. first provider with a configured API key
#   3. fall back to local Ollama at http://localhost:11434

# ────────────────────────────────────────────────────────────
# Provider · pick one as the default (others remain available)
# ────────────────────────────────────────────────────────────

UMBRIS_PROVIDER=anthropic   # anthropic | openai | ollama | custom

# ────────────────────────────────────────────────────────────
# Anthropic · recommended
# ────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-your-key-here

# ────────────────────────────────────────────────────────────
# OpenAI (works with OpenAI proper, Azure, and OpenAI-compatible gateways
# like groq / together / fireworks / openrouter / vLLM / litellm-proxy)
# ────────────────────────────────────────────────────────────

# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# ────────────────────────────────────────────────────────────
# Ollama · local, free, no key
# ────────────────────────────────────────────────────────────

# OLLAMA_HOST=http://localhost:11434

# ────────────────────────────────────────────────────────────
# Custos · autonomous sentinel
# ────────────────────────────────────────────────────────────

UMBRIS_COST_CAP_PER_CYCLE=5.00
UMBRIS_COST_CAP_PER_DAY=50.00
UMBRIS_CUSTOS_INTERVAL=2h
UMBRIS_CUSTOS_MODE=RAPID

# Optional webhook for cycle events (Slack / Discord incoming webhook URL)
# UMBRIS_CUSTOS_WEBHOOK=https://hooks.slack.com/services/...

# ────────────────────────────────────────────────────────────
# Studio · desktop app
# ────────────────────────────────────────────────────────────

# UMBRIS_STUDIO_PORT_HINT=8000     # the Tauri sidecar will pick a free port near this if set

# ────────────────────────────────────────────────────────────
# Telemetry · OFF by default
# ────────────────────────────────────────────────────────────

UMBRIS_TELEMETRY=off
